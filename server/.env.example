# Express Server Config Example
# Duplicate this file to '.env' and adjust settings.

# Backend HTTP Listening Port
PORT=5000

# PostgreSQL database connection URL
# Format: postgresql://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge_bot

# JSON Web Token sign secret key
JWT_SECRET=super_secret_key_for_knowledge_bot_jwt

# Ollama local connection config
OLLAMA_API_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_GEN_MODEL=gemma2:2b
