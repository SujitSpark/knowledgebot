# Expo Environment Variables Example
# Duplicate this file to '.env' and adjust settings.

# Local network URL of the backend GraphQL server.
# Replace <YOUR_LOCAL_IP> with your computer's local network IPv4 address (e.g. 192.168.1.50 or 10.42.102.167) 
# so that physical devices running Expo Go on the same Wi-Fi network can connect to the server.
EXPO_PUBLIC_API_URL=http://<YOUR_LOCAL_IP>:5000
